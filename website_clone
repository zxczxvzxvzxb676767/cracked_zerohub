async function addKey() {
    const token   = document.getElementById('adminToken').value.trim();
    const key     = document.getElementById('addKey').value.trim().toUpperCase();
    const discord = document.getElementById('addDiscord').value.trim();
    const hwid    = document.getElementById('addHwid').value.trim();
    const expiry  = document.getElementById('addExpiry').value.trim();
    const maps    = document.getElementById('addMaps').value.trim();
    
    if (!token)   { showToast('กรอก Admin Token ก่อน', 'warn'); return; }
    if (!key)     { showToast('กรอก License Key', 'warn'); return; }
    if (!discord) { showToast('กรอก Discord ID', 'warn'); return; }
    
    showToast('กำลังเพิ่ม Key...', 'info');
    try {
        let url = `${CONFIG.API_BASE}?action=add_key&token=${encodeURIComponent(token)}&key=${encodeURIComponent(key)}&discord=${encodeURIComponent(discord)}&expiry=${encodeURIComponent(expiry)}&maps=${encodeURIComponent(maps)}`;
        const res = await fetch(url);
        const data = await res.json();
        if (data.status === 'success') {
            showToast(`เพิ่ม Key สำเร็จ: ${key}`, 'success');
            document.getElementById('addKey').value = '';
            document.getElementById('addDiscord').value = '';
            document.getElementById('addHwid').value = '';
            await loadAllKeys();
        } else { showToast(`${data.msg || 'Error'}`, 'warn'); }
    } catch(e) { showToast('Connection failed', 'warn'); }
}

