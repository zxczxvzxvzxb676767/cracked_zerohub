function calculateDaysLeft(expiry) {
    if (!expiry || expiry === 'unlimited') return null;
    const today = new Date();
    const expDate = new Date(expiry);
    const diffTime = expDate - today;
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    return diffDays;
}

function formatMaps(mapsStr) {
    if (!mapsStr || mapsStr === 'all') return 'ทุก Scripts';
    const maps = mapsStr.split('|').map(m => m.trim());
    const mapNames = {
        'Deadline': 'Deadline',
        'Op1': 'Operation One',
        'AF': 'Auto Farm',
        'Blackout': 'Blackout',
        'BlackHawk': 'BlackHawk',
        'SCP': 'SCP Retrobreach'
    };
    return maps.map(m => mapNames[m] || m).join(', ');
}

function getScriptsList(mapsStr) {
    if (!mapsStr || mapsStr === 'all') return ['ZeroHub Blackout', 'ZeroHub Deadline', 'ZeroHub AF', 'ZeroHub Operation One', 'ZeroHub BlackHawk', 'ZeroHub SCP Retrobreach'];
    const maps = mapsStr.split('|').map(m => m.trim().toLowerCase());
    const scripts = [];
    if (maps.includes('blackout')) scripts.push('ZeroHub Blackout');
    if (maps.includes('deadline')) scripts.push('ZeroHub Deadline');
    if (maps.includes('af')) scripts.push('ZeroHub AF');
    if (maps.includes('op1')) scripts.push('ZeroHub Operation One');
    if (maps.includes('blackhawk')) scripts.push('ZeroHub BlackHawk');
    if (maps.includes('scp')) scripts.push('ZeroHub SCP Retrobreach');
    return scripts;
}

// ════════════════════════════
// LOGIN TRACKING (localStorage)
// ════════════════════════════
const LOGIN_LOG_KEY = 'zh_login_log';

function getLoginLog() {
    try { return JSON.parse(localStorage.getItem(LOGIN_LOG_KEY) || '[]'); } catch { return []; }
}
function saveLoginLog(log) {
    try { localStorage.setItem(LOGIN_LOG_KEY, JSON.stringify(log)); } catch {}
}
function recordLogin(user) {
    const log = getLoginLog();
    const alreadyToday = log.find(e => e.id === user.id && new Date(e.ts).toDateString() === new Date().toDateString());
    if (!alreadyToday) {
        log.unshift({ id: user.id, username: user.username, avatar: user.avatar, ts: new Date().toISOString() });
        if (log.length > 500) log.length = 500;
        saveLoginLog(log);
    }
}
function getLoginStats() {
    const log = getLoginLog();
    const now = new Date();
    const todayStr = now.toDateString();
    const weekAgo = new Date(now - 7 * 86400000);
    const uniqueIds = new Set(log.map(e => e.id));
    const todayEntries = log.filter(e => new Date(e.ts).toDateString() === todayStr);
    const todayUnique = new Set(todayEntries.map(e => e.id));
    const weekEntries = log.filter(e => new Date(e.ts) >= weekAgo);
    const weekUnique = new Set(weekEntries.map(e => e.id));
    return { total: uniqueIds.size, today: todayUnique.size, week: weekUnique.size, entries: log.slice(0, 20) };
}

