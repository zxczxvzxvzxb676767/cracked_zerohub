async function loadUserKeyInfo() {
    if (!currentUser) return;
    
    try {
        const token = CONFIG.ADMIN_TOKEN;
        const url = `${CONFIG.API_BASE}?action=list&token=${encodeURIComponent(token)}&_=${Date.now()}`;
        const res = await fetch(url);
        const data = await res.json();
        
        if (data.status === 'success' && data.keys) {
            const userKey = data.keys.find(k => k.discord === currentUser.id);
            if (userKey) {
                currentUserKeyInfo = userKey;
                updateDashboardKeyInfo(userKey);
            } else {
                currentUserKeyInfo = null;
                updateDashboardKeyInfo(null);
            }
        }
    } catch(e) {
        console.error('Failed to load user key info:', e);
    }
}

function updateDashboardKeyInfo(keyInfo) {
    const expiryItem = document.getElementById('mykey-expiry-item');
    const daysleftItem = document.getElementById('mykey-daysleft-item');
    const mapsItem = document.getElementById('mykey-maps-item');
    
    if (!keyInfo) {
        if (expiryItem) expiryItem.style.display = 'none';
        if (daysleftItem) daysleftItem.style.display = 'none';
        if (mapsItem) mapsItem.style.display = 'none';
        return;
    }
    
    if (expiryItem) expiryItem.style.display = 'block';
    if (daysleftItem) daysleftItem.style.display = 'block';
    if (mapsItem) mapsItem.style.display = 'block';
    
    // แสดงวันหมดอายุ
    const expiryEl = document.getElementById('mykey-expiry');
    const daysleftEl = document.getElementById('mykey-daysleft');
    const mapsEl = document.getElementById('mykey-maps');
    
    if (expiryEl) {
        if (keyInfo.expiry === 'unlimited') {
            expiryEl.innerHTML = '<span class="good">ไม่มีวันหมดอายุ</span>';
            expiryEl.className = 'my-key-info-value good';
        } else {
            expiryEl.textContent = keyInfo.expiry;
            expiryEl.className = 'my-key-info-value';
        }
    }
    
    if (daysleftEl) {
        const daysLeft = calculateDaysLeft(keyInfo.expiry);
        if (keyInfo.expiry === 'unlimited') {
            daysleftEl.innerHTML = '<span class="good">∞ ตลอดไป</span>';
            daysleftEl.className = 'my-key-info-value good';
        } else if (daysLeft !== null) {
            if (daysLeft < 0) {
                daysleftEl.innerHTML = '<span class="expired">หมดอายุแล้ว</span>';
                daysleftEl.className = 'my-key-info-value expired';
            } else if (daysLeft <= 3) {
                daysleftEl.innerHTML = `<span class="warn">${daysLeft} วัน (ใกล้หมดอายุ!)</span>`;
                daysleftEl.className = 'my-key-info-value warn';
            } else {
                daysleftEl.innerHTML = `<span class="good">${daysLeft} วัน</span>`;
                daysleftEl.className = 'my-key-info-value good';
            }
        }
    }
    
    if (mapsEl) {
        const scriptsList = getScriptsList(keyInfo.maps);
        const mapsHtml = scriptsList.map(s => `<span class="map-tag">${s}</span>`).join('');
        mapsEl.innerHTML = `<div class="maps-list">${mapsHtml}</div>`;
        mapsEl.className = 'my-key-info-value';
    }
}

