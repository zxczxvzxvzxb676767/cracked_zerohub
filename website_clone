function showPage(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
    const pg = document.getElementById(`page-${name}`);
    if (!pg) return;
    pg.classList.add('active');
    const navEl = document.getElementById(`nav-${name}`);
    if (navEl) navEl.classList.add('active');
    window.scrollTo(0, 0);
    if (name === 'shop')      renderProducts();
    if (name === 'key')       renderKeyPage();
    if (name === 'stats')     renderCommunityStats();
    if (name === 'dashboard') {
        const stats = getLoginStats();
        const dashEl = document.getElementById('dash-community-logins');
        if (dashEl) dashEl.textContent = stats.total;
        loadUserKeyInfo();
    }
}

