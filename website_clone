const video       = document.getElementById('bgVideo');
const soundIcon   = document.getElementById('soundIcon');
const soundIconBtn= document.getElementById('soundIconBtn');
const volumeSlider= document.getElementById('volumeSlider');
const volumePct   = document.getElementById('volumePct');
let isMuted = false;
const DEFAULT_VOLUME = 0.1;

function updateSliderTrack(val) {
    const pct = val + '%';
    volumeSlider.style.background =
        `linear-gradient(to right, var(--red) 0%, var(--red) ${pct}, rgba(255,255,255,0.1) ${pct}, rgba(255,255,255,0.1) 100%)`;
}

function setVolume(val) {
    const v = parseInt(val);
    video.volume = v / 100;
    volumePct.textContent = v + '%';
    updateSliderTrack(v);
    if (v === 0) {
        isMuted = true; soundIcon.className = 'fas fa-volume-xmark'; soundIconBtn.classList.remove('on');
    } else {
        isMuted = false;
        soundIcon.className = v < 50 ? 'fas fa-volume-low' : 'fas fa-volume-high';
        soundIconBtn.classList.add('on'); video.muted = false;
    }
}

function toggleMute() {
    isMuted = !isMuted; video.muted = isMuted;
    if (isMuted) { soundIcon.className = 'fas fa-volume-xmark'; soundIconBtn.classList.remove('on'); showToast('Sound off', 'info'); }
    else {
        const v = parseInt(volumeSlider.value);
        soundIcon.className = v < 50 ? 'fas fa-volume-low' : 'fas fa-volume-high';
        soundIconBtn.classList.add('on'); showToast('Sound on', 'success');
    }
}

