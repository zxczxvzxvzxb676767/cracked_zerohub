(function initLoading() {
    const bar      = document.getElementById('loadingBar');
    const label    = document.getElementById('loadingLabel');
    const enterBtn = document.getElementById('enterBtn');
    let progress   = 0;
    let videoReady = false;
    video.muted = true; video.playbackRate = 1.0;
    video.play().catch(() => {});
    const ticker = setInterval(() => {
        if (progress < (videoReady ? 92 : 78)) {
            progress += Math.random() * 10;
            bar.style.width = Math.min(progress, videoReady ? 92 : 78) + '%';
        }
    }, 180);
    function onVideoReady() {
        videoReady = true; clearInterval(ticker);
        bar.style.width = '100%'; label.textContent = 'Ready';
        enterBtn.style.display = 'inline-flex'; enterBtn.style.alignItems = 'center';
    }
    if (video.readyState >= 3) { setTimeout(onVideoReady, 400); }
    else {
        video.addEventListener('canplaythrough', () => setTimeout(onVideoReady, 400), { once: true });
        setTimeout(() => { if (!videoReady) onVideoReady(); }, 8000);
    }
})();

function enterSite() {
    const screen = document.getElementById('loadingScreen');
    video.volume = DEFAULT_VOLUME; video.muted = false; video.playbackRate = 1.0;
    video.play().catch(() => { video.muted = true; });
    updateSliderTrack(10);
    screen.classList.add('fade-out');
    setTimeout(() => { if (screen.parentNode) screen.remove(); }, 600);
}

