function loginWithDiscord() {
    sessionStorage.setItem('zh_return', 'dashboard');
    const params = new URLSearchParams({
        client_id:     CONFIG.DISCORD_CLIENT_ID,
        redirect_uri:  CONFIG.REDIRECT_URI,
        response_type: 'token',
        scope:         'identify guilds.members.read'
    });
    window.location.href = `https://discord.com/api/oauth2/authorize?${params}`;
}

async function handleDiscordCallback() {
    const hash = window.location.hash.slice(1);
    if (!hash) return false;
    const p     = new URLSearchParams(hash);
    const token = p.get('access_token');
    const type  = p.get('token_type') || 'Bearer';
    if (!token) return false;
    history.replaceState(null, null, window.location.pathname);
    showToast('กำลังโหลดข้อมูล...', 'info');
    try {
        const r = await fetch('https://discord.com/api/users/@me', { headers: { Authorization: `${type} ${token}` } });
        const u = await r.json();
        if (!u.id) throw new Error('bad user');
        sessionStorage.setItem('zh_user', JSON.stringify(u));
        sessionStorage.setItem('zh_token', token);
        recordLogin(u);
        applyUser(u);
        showToast('กำลังตรวจสอบ Role...', 'info');
        const hasRole = await checkUserRole(token);
        applyRoleUI(hasRole);
        if (hasRole) showToast('มี Key Access Role!', 'success');
        else showToast('ไม่มี Key Access Role', 'warn');
        await loadUserKeyInfo();
        const ret = sessionStorage.getItem('zh_return') || 'home';
        sessionStorage.removeItem('zh_return');
        showPage(ret);
        showToast(`ยินดีต้อนรับ, ${u.username}!`, 'success');
        return true;
    } catch(e) {
        showToast('Login ล้มเหลว กรุณาลองใหม่', 'warn');
        return false;
    }
}

function checkSavedLogin() {
    const s     = sessionStorage.getItem('zh_user');
    const token = sessionStorage.getItem('zh_token');
    if (!s) return false;
    try {
        const u = JSON.parse(s);
        applyUser(u);
        if (token) { checkUserRole(token).then(hasRole => { applyRoleUI(hasRole); loadUserKeyInfo(); }); }
        else applyRoleUI(false);
        return true;
    } catch {
        sessionStorage.removeItem('zh_user');
        sessionStorage.removeItem('zh_token');
        return false;
    }
}

function applyUser(u) {
    currentUser = u;
    const av = u.avatar
        ? `https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.png?size=128`
        : `https://cdn.discordapp.com/embed/avatars/${Number(u.discriminator||0)%5}.png`;
    document.getElementById('nav-auth-area').style.display = 'none';
    document.getElementById('nav-user-info').style.display = 'flex';
    document.getElementById('nav-avatar-img').src = av;
    document.getElementById('nav-username-text').textContent = u.username;
    document.getElementById('dash-avatar').src = av;
    document.getElementById('dash-name').textContent = u.username;
    document.getElementById('dash-tag').textContent = `Discord ID: ${u.id}`;
    document.getElementById('dash-discord-id').textContent = u.id;
    const myU = document.getElementById('mykey-username');
    const myI = document.getElementById('mykey-id');
    const myT = document.getElementById('mykey-time');
    if (myU) myU.textContent = u.username;
    if (myI) myI.textContent = u.id;
    if (myT) myT.textContent = new Date().toLocaleTimeString('th-TH');
    const stats = getLoginStats();
    const dashEl = document.getElementById('dash-community-logins');
    if (dashEl) dashEl.textContent = stats.total;
}

function logout() {
    currentUser = null; userHasKeyRole = false; roleCheckDone = false; currentUserKeyInfo = null;
    sessionStorage.removeItem('zh_user');
    sessionStorage.removeItem('zh_token');
    document.getElementById('nav-auth-area').style.display = '';
