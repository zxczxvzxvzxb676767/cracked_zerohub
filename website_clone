}

async function loadAllKeys() {
    const container = document.getElementById('keysTableContainer');
    const badge     = document.getElementById('keysCountBadge');
    if (!container || !badge) return;
    container.innerHTML = `<div class="empty-state"><div class="spinner-sm" style="margin:0 auto 10px;"></div>กำลังโหลด...</div>`;
    badge.textContent = '...';
    try {
        const token = document.getElementById('adminToken').value.trim() || CONFIG.ADMIN_TOKEN;
        const url = `${CONFIG.API_BASE}?action=list&token=${encodeURIComponent(token)}&_=${Date.now()}`;
        const res = await fetch(url);
        const data = await res.json();
        if (data.status !== 'success') throw new Error(data.msg || 'Failed to load keys');
        allParsedKeys = data.keys;
        badge.textContent = `${allParsedKeys.length} keys`;
        renderKeysTable(allParsedKeys);
        
        if (currentUser) loadUserKeyInfo();
    } catch(e) {
        badge.textContent = 'error';
        container.innerHTML = `<div class="empty-state"><i class="fas fa-triangle-exclamation" style="color:#fb923c;"></i>โหลดไม่สำเร็จ — ${e.message}</div>`;
        showToast('Failed to load keys', 'warn');
    }
}

function renderKeysTable(keys) {
    const container = document.getElementById('keysTableContainer');
    if (!container) return;
    if (keys.length === 0) {
        container.innerHTML = `<div class="empty-state"><i class="fas fa-inbox"></i>ไม่มี Keys ในระบบ</div>`;
        return;
    }
    container.innerHTML = `
    <div style="overflow-x:auto;">
    <table>
        <thead>
            <tr><th>#</th><th>LICENSE KEY</th><th>DISCORD ID</th><th>HWID</th><th>STATUS</th><th style="text-align:center;">RUNS</th><th>EXPIRY</th><th>MAPS</th><th>ACTIONS</th></tr>
        </thead>
        <tbody>
            ${keys.map((k, i) => {
                const isExpired = k.expiry !== 'unlimited' && new Date() > new Date(k.expiry);
                const statusClass = isExpired ? 'status-expired' : (k.hwid ? 'status-active' : 'status-inactive');
                const statusText = isExpired ? 'EXPIRED' : (k.hwid ? 'ACTIVE' : 'UNUSED');
                const expiryDisplay = k.expiry === 'unlimited' ? '<span class="expiry-badge unlimited">∞ Unlimited</span>' : `<span class="expiry-badge ${isExpired ? 'expired' : ''}">${k.expiry}</span>`;
                const mapsDisplay = k.maps === 'all' ? '<span class="map-tag">All Scripts</span>' : k.maps.split('|').map(m => `<span class="map-tag">${m}</span>`).join('');
                return `
                <tr>
                    <td style="color:var(--white-muted); font-size:0.75rem;">${i + 1}</td>
                    <td><div class="key-cell"><span>${escHtml(k.key)}</span><button class="btn-sm btn-sm-outline" style="padding:4px 9px; font-size:0.7rem;" onclick="copyText('${escHtml(k.key)}')"><i class="fas fa-copy"></i></button></div></td>
                    <td style="font-family:'JetBrains Mono',monospace; font-size:0.78rem; color:var(--white-muted);">${k.discord ? `<span style="color:#818cf8;">${escHtml(k.discord)}</span>` : '<span style="opacity:0.35;">—</span>'}</td>
                    <td style="font-family:'JetBrains Mono',monospace; font-size:0.72rem; color:var(--white-muted); max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${k.hwid ? escHtml(k.hwid) : '<span style="opacity:0.35;">—</span>'}</td>
                    <td><span class="key-status-badge ${statusClass}">${statusText}</span></td>
                    <td style="text-align:center;"><span class="run-count-badge ${k.run_count === 0 ? 'zero' : ''}">${k.run_count}</span></td>
                    <td>${expiryDisplay}</td>
                    <td><div class="maps-badge">${mapsDisplay}</div></td>
                    <td><div class="action-btns"><button class="btn-sm btn-sm-danger" onclick="confirmDeleteKey('${escHtml(k.key)}','${escHtml(k.discord)}')"><i class="fas fa-trash"></i> Delete</button><button class="btn-sm btn-sm-warn" onclick="quickResetHwid('${escHtml(k.key)}','${escHtml(k.discord)}')"><i class="fas fa-rotate-right"></i> Reset</button></div></td>
                </tr>`;
            }).join('')}
        </tbody>
    </table>
    </div>`;
}

function filterKeys(query) {
    const q = query.toLowerCase();
    renderKeysTable(allParsedKeys.filter(k =>
        k.key.toLowerCase().includes(q) || k.discord.toLowerCase().includes(q) || k.hwid.toLowerCase().includes(q)
    ));
}

function escHtml(str) {
    return String(str)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

