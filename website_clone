async function checkUserRole(accessToken) {
    if (!accessToken) { roleCheckDone = true; return false; }
    try {
        const res = await fetch(
            `https://discord.com/api/users/@me/guilds/${CONFIG.REQUIRED_GUILD_ID}/member`,
            { headers: { Authorization: `Bearer ${accessToken}` } }
        );
        if (!res.ok) { roleCheckDone = true; return false; }
        const member = await res.json();
        const hasRole = (member.roles || []).includes(CONFIG.REQUIRED_ROLE_ID);
        roleCheckDone = true;
        return hasRole;
    } catch(e) { roleCheckDone = true; return false; }
}

function applyRoleUI(hasRole) {
